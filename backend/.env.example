# Backend Environment Variables
# Copy this file to .env and update with your settings

# PostgreSQL Connection String
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/pipeline_gis

# Enable SQL query logging (for debugging)
# Set to "true" to log all SQL queries; "false" for production
SQL_ECHO=false

# FastAPI Server Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Auto-reload on code changes (disable in production)
# Set to "true" for development, "false" for production
API_RELOAD=true

# Logging Level
LOG_LEVEL=INFO

# Optional: Sentry error tracking
# SENTRY_DSN=https://...@sentry.io/...

# Optional: Database connection pooling
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=40
