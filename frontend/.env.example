# Frontend Environment Variables
# Copy this file to .env and update with your settings

# Mapbox GL JS Access Token
# Get free token at https://account.mapbox.com/tokens/
# Format: pk_... (public token)
VITE_MAPBOX_TOKEN=pk_your_mapbox_token_here

# Backend API URL
# Development: http://localhost:8000
# Production: https://api.example.com
VITE_API_URL=http://localhost:8000

# Optional: Application Title
# VITE_APP_TITLE=Intelligent Pipeline System

# Optional: Debug Mode
# VITE_DEBUG=false
